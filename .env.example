# ── GitHub Actions Variables (Settings → Variables) ──────────────────────────
# Firebase Web Config (non-sensitive, designed to be public)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Google Calendar
GOOGLE_CALENDAR_ID=

# ── GitHub Actions Secrets (Settings → Secrets) ───────────────────────────────
# Google Calendar API key (protect to avoid quota abuse)
GOOGLE_CALENDAR_API_KEY=

# Firebase Cloud Messaging VAPID key (push notifications auth)
FCM_WEB_VAPID_KEY=
